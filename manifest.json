{
  "manifest_version": 3,
  "name": "WhyTab",
  "version": "3.0.0",
  "description": "Track your open tabs and surface forgotten ones before they pile up.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "WhyTab",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["content.js", "content.css"],
      "matches": ["<all_urls>"]
    }
  ]
}